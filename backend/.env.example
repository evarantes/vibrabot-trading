# Configurações do CodexiaAuditor

# URL do banco de dados (padrão: SQLite local)
DATABASE_URL=sqlite:///./codexia_auditor.db

# Chave da API OpenAI (opcional - para análise com IA avançada)
# Sem esta chave, o sistema usa análise heurística interna
OPENAI_API_KEY=sk-...

# Porta do servidor (padrão: 8000)
PORT=8000
